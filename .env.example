# Local development environment variables
# Copy to .env and fill in values:
#   cp .env.example .env
# Do NOT commit .env — it is git-ignored.

# ─── LLM ────────────────────────────────────────────────────────────────────
# Provider: anthropic | openai | ollama
HATCH_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ─── Embeddings ──────────────────────────────────────────────────────────────
# Provider: openai | ollama
HATCH_EMBED_PROVIDER=ollama
OPENAI_API_KEY=

# ─── Server ──────────────────────────────────────────────────────────────────
HATCH_SSH_PORT=2222
HATCH_HTTP_PORT=8080

# ─── Auth ────────────────────────────────────────────────────────────────────
# HATCH_WEB_PASSWORD: web dashboard password (pre-JWT, until Milestone 9 / v1.0.0)
HATCH_WEB_PASSWORD=changeme
# HATCH_JWT_SECRET: required from Milestone 9 onward — generate with:
#   openssl rand -hex 32
HATCH_JWT_SECRET=

# ─── Database ────────────────────────────────────────────────────────────────
HATCH_DB_PATH=~/.hatch/hatch.db
