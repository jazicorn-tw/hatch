# 1Password secret references for hatch.
#
# This file contains op:// URIs — NOT actual secrets — so it is safe to
# commit to version control. Secrets are resolved at command-execution time
# by the 1Password CLI.
#
# Usage:
#   op run --env-file .env.op -- hatch ingest --source=<name>
#   op run --env-file .env.op -- go test ./...
#   op run --env-file .env.op -- hatch <command>
#
# One-time setup: make sure 1Password CLI is installed and you are signed in:
#   brew install --cask 1password/tap/1password-cli
#   eval $(op signin)

# --- LLM API keys ---
# Only include entries for keys you have stored in 1Password.
# op run will error on any op:// reference it cannot resolve.
ANTHROPIC_API_KEY=op://Private/ANTHROPIC_API_KEY/credential
# OPENAI_API_KEY=op://Private/OPENAI_API_KEY/credential    ← uncomment if you have this
# GOOGLE_API_KEY=op://Private/GEMINI_API_KEY/credential    ← uncomment if you have this
