#!/usr/bin/env bash
set -euo pipefail

# dev — gum-powered dev task runner for Hatch
#
# Usage:
#   ./dev                  interactive menu (requires TTY)
#   ./dev <task>           run task directly
#   ./dev <task> <sub>     run namespaced task (e.g. ./dev docker up)
#
# Tasks:
#   format                 auto-format Go source (gofmt)
#   lint                   static analysis (go vet + markdownlint)
#   lint:docs              lint markdown files only
#   test                   run go tests
#   verify                 doctor + lint + test
#   quality                doctor + format + lint + test
#   pre-commit             run pre-commit gate (format + lint + test)
#   bootstrap              first-time setup (hooks + doctor + quality)
#   doctor                 validate local dev environment
#   hooks                  install git hooks
#   exec-bits              check + fix executable bits on scripts and hooks
#   build                  compile hatch binary to ./hatch
#   build run [args...]    build then run ./hatch with resolved secrets
#   run                    start the application (go run, no args)
#   env up                 start local dev environment (Colima + Docker)
#   env down               stop local dev environment
#   env status             show dev environment status
#   docker up              start Docker Compose services
#   docker down            stop Docker Compose services
#   docker reset           reset Docker Compose (down -v + up)
#   test-ci                run local-safe workflows via act: ci, doctor, changelog-guard
#   test-ci <workflow>     run a specific workflow (e.g. test-ci ci, test-ci release)
#   changelog              preview semantic-release changelog (dry-run, no release)
#   clean local            clean local build artifacts
#   clean docker           clean Docker build cache
#   clean colima           reset Colima (destructive)
#   tags                   list all allowed tags (both + docs sections)
#
# Overrides (one-off):
#   AUTO_FORMAT=0 ./dev pre-commit   skip format step
#   SKIP_TESTS=1  ./dev pre-commit   skip test step

# ── Load task modules ─────────────────────────────────────────────────────────

_DEV_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.dev"

source "$_DEV_DIR/helpers.sh"
source "$_DEV_DIR/go.sh"
source "$_DEV_DIR/lint.sh"
source "$_DEV_DIR/quality.sh"
source "$_DEV_DIR/infra.sh"
source "$_DEV_DIR/env.sh"
source "$_DEV_DIR/docker.sh"
source "$_DEV_DIR/ci.sh"
source "$_DEV_DIR/release.sh"
source "$_DEV_DIR/clean.sh"
source "$_DEV_DIR/tags.sh"

# ── Task resolution ───────────────────────────────────────────────────────────

TASK="${1:-}"
SUBTASK="${2:-}"

# Combine task + subtask for namespaced tasks (e.g. "docker up" → "docker:up")
if [[ -n "$SUBTASK" ]]; then
  TASK="${TASK}:${SUBTASK}"
fi

# No args + TTY → interactive menu
if [[ -z "$TASK" ]]; then
  if [[ ! -t 0 ]]; then
    log_error "no task specified and no TTY for interactive menu"
    exit 1
  fi
  TASK=$($GUM choose \
    "format" \
    "lint" \
    "test" \
    "verify" \
    "quality" \
    "bootstrap" \
    "doctor" \
    "exec-bits" \
    "build" \
    "build run" \
    "run" \
    "env up" \
    "env down" \
    "env status" \
    "docker up" \
    "docker down" \
    "docker reset" \
    "test-ci" \
    "changelog" \
    "tags" \
    "clean local" \
    "clean docker" \
    "clean colima")
  # Normalize space-based selection from menu to colon-form
  TASK="${TASK/ /:}"
fi

# ── Dispatch ──────────────────────────────────────────────────────────────────

case "$TASK" in
  format)            run_format ;;
  lint)              run_lint ;;
  lint:docs)         run_lint_docs ;;
  test)              run_test ;;
  verify)            run_verify ;;
  quality)           run_quality ;;
  pre-commit)        run_pre_commit ;;
  bootstrap)         run_bootstrap ;;
  doctor)            run_doctor ;;
  hooks)             run_hooks ;;
  exec-bits)         run_exec_bits ;;
  build)             run_build ;;
  build:run)         run_build_run "${@:3}" ;;
  run)               run_run ;;
  env:up)            run_env_up ;;
  env:down)          run_env_down ;;
  env:status)        run_env_status ;;
  env:init)          run_env_init ;;
  docker:up)         run_docker_up ;;
  docker:down)       run_docker_down ;;
  docker:reset)      run_docker_reset ;;
  test-ci|test-ci:*) run_test_ci "${TASK#test-ci:}" ;;
  changelog)         run_changelog ;;
  clean:local)       run_clean_local ;;
  clean:docker)      run_clean_docker ;;
  clean:colima)      run_clean_colima ;;
  tags)              run_tags ;;
  *)
    log_error "unknown task: $TASK"
    echo ""
    echo "Run './dev' with no arguments for an interactive menu."
    exit 1
    ;;
esac
