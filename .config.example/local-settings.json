{
  "checks": {
    "executableBits": {
      "strict": 2,
      "autoStage": true
    },
    "lineEndings": {
      "enforce": true
    },
    "filePermissions": {
      "warnOnGroupWrite": true
    }
  },
  "git": {
    "autoInstallHooks": true,
    "releaseConfirm": {
      "strictDefault": false
    },
    "preAddLint": {
      "enabled": true
    }
  },
  "local": {
    "host": "localhost",
    "app": { "port": 8080 }
  },
  "doctor": {
    "minDockerMemGb": 4,
    "minDockerCpus": 2,
    "requireColimaRunning": false
  },
  "colima": {
    "profile": "default",
    "required": { "memGib": 8, "cpu": 6 },
    "tolerance": { "gib": 0.25 }
  }
}
